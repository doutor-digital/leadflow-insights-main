# URL base da API (sem barra no final). O Vite só expõe variáveis com prefixo VITE_.
VITE_API_BASE_URL=https://sua-api.exemplo.com

# ID da clínica (métricas, dashboard, operações, relatórios filtrados).
VITE_CLINIC_ID=

# Chave admin para GET/POST/DELETE /api/config/cloudia-api-key (header X-Admin-Key).
VITE_ADMIN_KEY=
